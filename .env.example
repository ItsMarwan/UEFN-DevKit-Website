# ──────────────────────────────────────────────────────────────
# hCaptcha
# Get your keys at: https://www.hcaptcha.com/
# ──────────────────────────────────────────────────────────────

# Public site key (used in the browser)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# Secret key (used server-side to verify tokens)
HCAPTCHA_SECRET_KEY=XX_YYXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ──────────────────────────────────────────────────────────────
# Node Environment
# ──────────────────────────────────────────────────────────────
NODE_ENV=production

# ──────────────────────────────────────────────────────────────
# Email — Resend (recommended, easiest setup)
# Get your API key at: https://resend.com/
# ──────────────────────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# The email address where contact form submissions get sent
CONTACT_TO_EMAIL=email@example.com

FLASK_API_URL=http://XXX.YYY/api/
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ──────────────────────────────────────────────────────────────
# Rate Limiting — Upstash Redis (optional but recommended)
# Set up free tier at: https://console.upstash.com/
# ──────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# ──────────────────────────────────────────────────────────────
# Notes:
# 1. NEXT_PUBLIC_* variables are exposed to the browser
# 2. Other variables are server-side only (secure)
# 3. Copy this file: cp .env.example .env.local
# 4. Fill in your actual values in .env.local
# 5. Never commit .env.local to git
# ──────────────────────────────────────────────────────────────
